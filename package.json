{
	"name": "qcp",
	"version": "0.1.1-alpha.5",
	"description": "AI-powered CLI for querying PostgreSQL in natural language",
	"type": "module",
	"bin": {
		"qcp": "./dist/qcp.js"
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "bun run src/cli/index.ts",
		"build": "bun build ./src/cli/index.ts --target=node --outdir=dist --outfile=qcp.js",
		"build:bun": "bun build ./src/cli/index.ts --target=bun --outdir=dist --outfile=qcp-bun.js",
		"build:binary": "bun build ./src/cli/index.ts --compile --outfile=dist/qcp",
		"build:binary:macos-arm64": "bun build ./src/cli/index.ts --compile --target=bun-macos-arm64 --outfile=dist/qcp-macos-arm64",
		"build:binary:macos-x64": "bun build ./src/cli/index.ts --compile --target=bun-darwin-x64 --outfile=dist/qcp-macos-x64",
		"build:binary:linux-x64": "bun build ./src/cli/index.ts --compile --target=bun-linux-x64 --outfile=dist/qcp-linux-x64",
		"build:binary:linux-arm64": "bun build ./src/cli/index.ts --compile --target=bun-linux-arm64 --outfile=dist/qcp-linux-arm64",
		"build:binary:windows-x64": "bun build ./src/cli/index.ts --compile --target=bun-windows-x64 --outfile=dist/qcp-windows-x64.exe",
		"build:all-binaries": "bun run build:binary:macos-arm64 && bun run build:binary:macos-x64 && bun run build:binary:linux-x64 && bun run build:binary:linux-arm64 && bun run build:binary:windows-x64",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"lint": "bunx tsc --noEmit",
		"prepublishOnly": "bun run build",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"keywords": [
		"postgresql",
		"ai",
		"cli",
		"natural-language",
		"sql",
		"gemini",
		"openai",
		"database"
	],
	"author": "Moduna AI",
	"license": "MIT",
	"homepage": "https://github.com/Moduna-AI/qcp",
	"repository": {
		"type": "git",
		"url": "https://github.com/Moduna-AI/qcp.git"
	},
	"bugs": {
		"url": "https://github.com/Moduna-AI/qcp/issues"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.105.0",
		"@google/generative-ai": "^0.24.0",
		"archiver": "^8.0.0",
		"chalk": "^5.3.0",
		"cli-table3": "^0.6.5",
		"commander": "^13.0.0",
		"dotenv": "^16.4.5",
		"inquirer": "^12.0.0",
		"openai": "^6.0.0",
		"ora": "^8.0.0",
		"pgsql-ast-parser": "^12.0.2",
		"postgres": "^3.4.9",
		"posthog-node": "^5.0.0",
		"uuid": "^11.0.3",
		"winston": "^3.17.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/archiver": "^8.0.0",
		"@types/bun": "latest",
		"typescript": "^6.0.3"
	}
}
