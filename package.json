{
	"name": "@moduna/qcp",
	"version": "0.3.1",
	"description": "AI-powered CLI for querying PostgreSQL in natural language",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./web": {
			"types": "./dist/web.d.ts",
			"import": "./dist/web.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		},
		"./safety": {
			"types": "./dist/safety/index.d.ts",
			"import": "./dist/safety/index.js"
		},
		"./schema": {
			"types": "./dist/schema/index.d.ts",
			"import": "./dist/schema/index.js"
		},
		"./db": {
			"types": "./dist/db/index.d.ts",
			"import": "./dist/db/index.js"
		},
		"./runtime": {
			"types": "./dist/runtime.d.ts",
			"import": "./dist/runtime.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"qcp": "dist/qcp.js"
	},
	"workspaces": [
		"apps/*"
	],
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "bun run src/cli/index.ts",
		"build": "bun run build:cli && bun run build:sdk && bun run build:types",
		"build:cli": "bun build ./src/cli/index.ts --target=node --outfile=dist/qcp.js",
		"build:sdk": "bun build ./src/index.ts ./src/web.ts ./src/types/index.ts ./src/safety/index.ts ./src/schema/index.ts ./src/db/index.ts ./src/runtime.ts --target=node --format=esm --splitting --outdir=dist",
		"build:types": "bunx tsc -p tsconfig.build.json",
		"build:bun": "bun build ./src/cli/index.ts --target=bun --outfile=dist/qcp-bun.js",
		"build:binary": "bun build ./src/cli/index.ts --compile --outfile=dist/qcp",
		"build:binary:macos-arm64": "bun build ./src/cli/index.ts --compile --target=bun-macos-arm64 --outfile=dist/qcp-macos-arm64",
		"build:binary:linux-x64": "bun build ./src/cli/index.ts --compile --target=bun-linux-x64 --outfile=dist/qcp-linux-x64",
		"build:binary:linux-arm64": "bun build ./src/cli/index.ts --compile --target=bun-linux-arm64 --outfile=dist/qcp-linux-arm64",
		"build:binary:windows-x64": "bun build ./src/cli/index.ts --compile --target=bun-windows-x64 --outfile=dist/qcp-windows-x64.exe",
		"build:all-binaries": "bun run build:binary:macos-arm64 && bun run build:binary:linux-x64 && bun run build:binary:linux-arm64 && bun run build:binary:windows-x64",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"type-check": "bunx tsc --noEmit",
		"lint": "bunx tsc --noEmit",
		"prepublishOnly": "bun run build",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"keywords": [
		"postgresql",
		"ai",
		"cli",
		"natural-language",
		"sql",
		"gemini",
		"openai",
		"database"
	],
	"author": "Moduna AI",
	"license": "MIT",
	"homepage": "https://github.com/Moduna-AI/qcp",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Moduna-AI/qcp.git"
	},
	"bugs": {
		"url": "https://github.com/Moduna-AI/qcp/issues"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"cli-table3": "^0.6.5",
		"commander": "^15.0.0",
		"dotenv": "^17.4.2",
		"inquirer": "^14.0.2",
		"ora": "^9.4.1",
		"pgsql-ast-parser": "^12.0.2",
		"postgres": "^3.4.9",
		"uuid": "^14.0.1",
		"winston": "^3.19.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@anthropic-ai/sdk": "^0.111.0",
		"@biomejs/biome": "^2.5.3",
		"@google/generative-ai": "^0.24.1",
		"@mastra/core": "^1.50.1",
		"@mastra/mcp": "^1.13.1",
		"@types/archiver": "^8.0.0",
		"@types/bun": "^1.3.14",
		"@types/inquirer": "^9.0.10",
		"@types/node": "^26.1.1",
		"@types/uuid": "^11.0.0",
		"archiver": "^8.0.0",
		"bun-types": "1.3.14",
		"mastra": "^1.18.2",
		"openai": "^6.46.0",
		"posthog-node": "^5.41.0",
		"prisma": "^7.8.0",
		"typescript": "^7.0.2"
	}
}
