# qcp Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Database connection URL
# QCP_DATABASE_URL=postgres://readonly_user:password@localhost:5432/mydb
# Prisma Postgres connection URL (used when databaseType is prisma-postgres)
# PRISMA_DATABASE_URL=postgres://readonly_user:password@pooled.db.prisma.io:5432/postgres?sslmode=require

# AI Provider API Keys (only one needed — matches your configured provider)
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Cloud automation control plane
# QCP_AUTOMATION_CONTROL_URL=https://automation.example.com
# QCP_AUTOMATION_CONTROL_TOKEN=...

# Inngest automation worker
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...
# QCP_AUTOMATION_INNGEST_APP_ID=qcp-automation
# QCP_AUTOMATION_DATABASE_URL=postgres://automation_registry_user:password@host:5432/qcp_automation
# QCP_AUTOMATION_CODEX_MODEL=...
# QCP_AUTOMATION_QCP_PROVIDER=openai
# QCP_AUTOMATION_QCP_MODEL=...

# Per-connection secret refs used by qcp.ask.readonly automation specs
# QCP_AUTOMATION_DB_PROD_URL=postgres://readonly_user:password@host:5432/prod

# Ollama (if using local models)
# OLLAMA_HOST=http://localhost:11434

# Debug logging
# QCP_LOG_LEVEL=debug
# QCP_DEBUG=1

# Override install source label (used by installer scripts)
# QCP_INSTALL_SOURCE=binary
